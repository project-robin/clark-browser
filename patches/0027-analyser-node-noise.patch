# clark-stealth-chromium patch #27 — seed-derived noise on AnalyserNode
# getFloatFrequencyData / getByteFrequencyData output.
#
# Detection sites that read the frequency domain via AnalyserNode instead of
# the AudioContext destination buffer would bypass patch #26. This patch
# perturbs the per-bin magnitude by a tiny seed-derived amount so the
# frequency-domain hash diverges from stock Chrome while staying visually
# identical on a spectrogram.
#
# Source: chromium 148.0.7778.96
#   third_party/blink/renderer/modules/webaudio/analyser_node.cc
diff --git a/third_party/blink/renderer/modules/webaudio/analyser_node.cc b/third_party/blink/renderer/modules/webaudio/analyser_node.cc
--- a/third_party/blink/renderer/modules/webaudio/analyser_node.cc
+++ b/third_party/blink/renderer/modules/webaudio/analyser_node.cc
@@ -2,6 +2,12 @@
 // Use of this source code is governed by a BSD-style license that can be
 // found in the LICENSE file.
 
+#include "base/command_line.h"
+#include "third_party/blink/common/clark_fingerprint_switches.h"
+#include "third_party/blink/common/clark_seed.h"
+
 #include "third_party/blink/renderer/modules/webaudio/analyser_node.h"
 
 #include <algorithm>
@@ -100,6 +106,42 @@ void AnalyserNode::GetFloatFrequencyData(NotShared<DOMFloat32Array> array,
                                         unsigned index) {
+  // clark-stealth #27: apply seed-derived per-bin noise to the frequency
+  // domain output. The perturbation is ~1e-7 relative — well below the
+  // quantization noise floor of a 2048-bin FFT — but sufficient to break
+  // the sum-of-abs hash that audio fingerprint libraries compute on
+  // AnalyserNode output.
+  auto clark_apply_analyser_noise_f32 = [](float* data, size_t n) {
+    auto* cl = base::CommandLine::ForCurrentProcess();
+    if (!cl->HasSwitch(clark::switches::kFingerprint)) return;
+    if (!clark::seed::NoiseEnabled()) return;
+    const uint64_t h = clark::seed::Hash("audio.analyser");
+    const double scale =
+        1.0 + (static_cast<double>(h & 0xFFFFu) - 32768.0) * 3.0e-11;
+    const float offset = static_cast<float>(
+        (static_cast<double>((h >> 16) & 0xFFFFu) - 32768.0) * 1.0e-7);
+    for (size_t i = 0; i < n; ++i) {
+      data[i] = static_cast<float>(data[i] * scale) + offset;
+    }
+  };
+
+  auto clark_apply_analyser_noise_u8 = [](uint8_t* data, size_t n) {
+    auto* cl = base::CommandLine::ForCurrentProcess();
+    if (!cl->HasSwitch(clark::switches::kFingerprint)) return;
+    if (!clark::seed::NoiseEnabled()) return;
+    const uint64_t h = clark::seed::Hash("audio.analyser");
+    // +/-1 LSB perturbation, deterministic by bin index.
+    for (size_t i = 0; i < n; ++i) {
+      uint64_t mix = h ^ (static_cast<uint64_t>(i) * 0x9E3779B97F4A7C15ULL);
+      int delta = static_cast<int>(mix & 0x1);
+      if ((mix >> 1) & 1) {
+        data[i] = std::min<int>(255, data[i] + delta);
+      } else {
+        data[i] = std::max<int>(0, data[i] - delta);
+      }
+    }
+  };
+
   DCHECK(IsMainThread());
 
   // The AnalyserNode should have been cleaned up by off-line context finishing.
@@ -120,6 +162,14 @@ void AnalyserNode::GetFloatFrequencyData(NotShared<DOMFloat32Array> array,
     return;
   }
 
+  // clark-stealth #27: perturb float frequency data after the FFT copy.
   array->SetNarrow<double>(DataRange(), 0, down_mix_.Data(),
                            number_of_bins);
+
+  if (array && array->length()) {
+    auto span = array->AsSpan();
+    clark_apply_analyser_noise_f32(span.data(), span.size());
+  }
 }
 
 void AnalyserNode::GetByteFrequencyData(NotShared<DOMUint8Array> array,
@@ -140,6 +190,14 @@ void AnalyserNode::GetByteFrequencyData(NotShared<DOMUint8Array> array,
     return;
   }
 
+  // clark-stealth #27: perturb byte frequency data after the quantization.
   const double* source = down_mix_.Data();
   for (unsigned i = 0; i < number_of_bins; ++i) {
     double scaled_value = BiquadFilter::DbToLinear(source[i]);
     double db_mag = scaled_value * kDecibelRange;
+
+    // Apply per-bin noise before clamping to [0,255].
+    {
+      auto* cl = base::CommandLine::ForCurrentProcess();
+      if (cl->HasSwitch(clark::switches::kFingerprint) &&
+          clark::seed::NoiseEnabled()) {
+        const uint64_t h = clark::seed::Hash("audio.analyser");
+        uint64_t mix = h ^ (static_cast<uint64_t>(i) * 0x9E3779B97F4A7C15ULL);
+        double noise = ((mix & 0x1) ? 1.0 : -1.0) * (1.0 / 255.0);
+        scaled_value += noise;
+      }
+    }
+
     // byte_data is a 0-255 scaled value.
     // 0 being -100dB and 255 being 0dB.
     int byte_data = static_cast<int>(255 * db_mag);
