 namespace blink {

+namespace {
+
+bool ClarkPermissionPromptDefaultEnabled() {
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  return cl->HasSwitch(clark::switches::kFingerprint) ||
+         cl->HasSwitch(clark::switches::kFingerprintPlatform) ||
+         cl->HasSwitch(clark::switches::kFingerprintBrand) ||
+         cl->HasSwitch(clark::switches::kFingerprintBrandVersion);
+}
+
+bool ClarkPromptablePermission(
+    const mojom::blink::PermissionDescriptor& descriptor) {
+  switch (descriptor.name) {
+    case mojom::blink::PermissionName::NOTIFICATIONS:
+    case mojom::blink::PermissionName::GEOLOCATION:
+    case mojom::blink::PermissionName::AUDIO_CAPTURE:
+    case mojom::blink::PermissionName::VIDEO_CAPTURE:
+    case mojom::blink::PermissionName::CLIPBOARD_READ:
+    case mojom::blink::PermissionName::CLIPBOARD_WRITE:
+      return true;
+    default:
+      return false;
+  }
+}
+
+mojom::blink::PermissionStatus ClarkPermissionPromptDefault(
+    mojom::blink::PermissionStatus status,
+    const mojom::blink::PermissionDescriptor& descriptor) {
+  // clark-stealth #48: in fingerprint mode, headless can auto-deny promptable
+  // permissions before the user has made a decision. Expose the fresh-profile
+  // Permissions API state instead.
+  if (status == mojom::blink::PermissionStatus::DENIED &&
+      ClarkPermissionPromptDefaultEnabled() &&
+      ClarkPromptablePermission(descriptor)) {
+    return mojom::blink::PermissionStatus::ASK;
+  }
+  return status;
+}
+
