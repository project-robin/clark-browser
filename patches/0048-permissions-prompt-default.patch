# Idea: stock/headless Chromium can surface "denied" for promptable
# permissions. Bot detectors flag the headless auto-deny; "prompt" matches a
# fresh real Chrome profile before the user decides.
diff --git a/third_party/blink/renderer/modules/permissions/permission_status.cc b/third_party/blink/renderer/modules/permissions/permission_status.cc
