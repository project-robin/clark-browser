# clark-stealth-chromium patch #10 - Notification.permission defaults to
# "default" under Clark fingerprint mode.
#
# Source: chromium 148.0.7778.96
#   third_party/blink/renderer/modules/notifications/notification.cc
diff --git a/third_party/blink/renderer/modules/notifications/notification.cc b/third_party/blink/renderer/modules/notifications/notification.cc
--- a/third_party/blink/renderer/modules/notifications/notification.cc
+++ b/third_party/blink/renderer/modules/notifications/notification.cc
@@ -32,0 +33 @@
+#include "base/command_line.h"
@@ -36,0 +38 @@
+#include "chrome/common/clark_fingerprint_switches.h"
@@ -68,0 +71,24 @@
+namespace {
+
+bool ClarkNotificationPromptDefaultEnabled() {
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  return cl->HasSwitch(clark::switches::kFingerprint) ||
+         cl->HasSwitch(clark::switches::kFingerprintPlatform) ||
+         cl->HasSwitch(clark::switches::kFingerprintBrand) ||
+         cl->HasSwitch(clark::switches::kFingerprintBrandVersion);
+}
+
+mojom::blink::PermissionStatus ClarkNotificationPromptDefault(
+    mojom::blink::PermissionStatus status) {
+  // clark-stealth #10: headless/fingerprint mode can surface "denied" even
+  // when a fresh real Chrome profile reports Notification.permission as
+  // "default". Convert that automation tell back to the prompt/default state.
+  if (status == mojom::blink::PermissionStatus::DENIED &&
+      ClarkNotificationPromptDefaultEnabled()) {
+    return mojom::blink::PermissionStatus::ASK;
+  }
+  return status;
+}
+
+}  // namespace
+
@@ -422,0 +449,2 @@
+  // clark-stealth #10: keep the direct getter aligned with
+  // permissions.query({name: "notifications"}) for fingerprint smoke probes.
@@ -423,0 +452,2 @@
+    if (ClarkNotificationPromptDefaultEnabled())
+      return V8NotificationPermission(V8NotificationPermission::Enum::kDefault);
@@ -437,0 +468 @@
+  status = ClarkNotificationPromptDefault(status);
