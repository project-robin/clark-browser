+    // clark-stealth #21: per-byte +/-1 noise on UNSIGNED_BYTE readbacks,
+    // deterministic by clark seed. Defeats canvas/WebGL pixel hash
+    // fingerprinting while keeping output visually identical.
+    if (clark::seed::NoiseEnabled() && type == GL_UNSIGNED_BYTE && data) {
+      uint64_t seed_h = clark::seed::Hash("webgl-rp");
+      size_t n = static_cast<size_t>(width) * static_cast<size_t>(height) * 4;
+      // Cap the byte count to avoid pathological cases.
+      if (n > 0 && n <= 64u * 1024u * 1024u) {
+        for (size_t i = 0; i < n; ++i) {
+          uint64_t mix = seed_h ^ (static_cast<uint64_t>(i) * 0x9E3779B97F4A7C15ULL);
+          int8_t delta = static_cast<int8_t>(mix & 0x1);
+          if ((mix >> 1) & 1) {
+            data[i] = std::min<int>(255, data[i] + delta);
+          } else {
+            data[i] = std::max<int>(0, data[i] - delta);
+          }
+        }
+      }
+    }
