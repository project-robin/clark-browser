+    {"Apple Inc.", "Apple GPU"},
+    {"Mesa", "llvmpipe (LLVM 17.0.6, 256 bits)"},
+};
+
+const GpuPoolEntry& ClarkPickGpu() {
+  return clark::seed::Pick(kGpuPool, "webgl-pool");
