# clark-stealth-chromium patch #41 — flip chrome/* stealth defaults
# Source: chromium 148.0.7778.96 chrome/common/chrome_features.cc + chrome/browser/browser_features.cc
# Idea: enable kNoReferrers (drops Referer header) and kClearDataOnExit
# (clears cookies/storage on exit). Both reduce cross-session linkability.
diff --git a/chrome/browser/browser_features.cc b/chrome/browser/browser_features.cc
index 794e2959cc..66784de31e 100644
--- a/chrome/browser/browser_features.cc
+++ b/chrome/browser/browser_features.cc
@@ -248,5 +248,5 @@ BASE_FEATURE(kAutoDeElevate, base::FEATURE_ENABLED_BY_DEFAULT);
 // show both in Chrome Tabs and Windows.
 BASE_FEATURE(kRemovalOfIWAsFromTabCapture, base::FEATURE_ENABLED_BY_DEFAULT);
 
-BASE_FEATURE(kClearDataOnExit, "ClearDataOnExit", base::FEATURE_DISABLED_BY_DEFAULT);
+BASE_FEATURE(kClearDataOnExit, "ClearDataOnExit", base::FEATURE_ENABLED_BY_DEFAULT);  // clark-stealth: clear cookies/storage on exit
 }  // namespace features
diff --git a/chrome/common/chrome_features.cc b/chrome/common/chrome_features.cc
index 2ba634187b..cd8f460e83 100644
--- a/chrome/common/chrome_features.cc
+++ b/chrome/common/chrome_features.cc
@@ -1235,7 +1235,7 @@ BASE_FEATURE(kNewMacNotificationAPI, base::FEATURE_DISABLED_BY_DEFAULT);
 
 // When kNoReferrers is enabled, most HTTP requests will provide empty
 // referrers instead of their ordinary behavior.
-BASE_FEATURE(kNoReferrers, base::FEATURE_DISABLED_BY_DEFAULT);
+BASE_FEATURE(kNoReferrers, base::FEATURE_ENABLED_BY_DEFAULT);  // clark-stealth: no Referer header
 
 #if BUILDFLAG(IS_ANDROID)
 BASE_FEATURE(kOfflineAutoFetch, base::FEATURE_ENABLED_BY_DEFAULT);
