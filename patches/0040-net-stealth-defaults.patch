# clark-stealth-chromium patch #40 — flip net/network stealth defaults
# Source: chromium 148.0.7778.96 net/base/features.cc + services/network/public/cpp/features.cc
# Idea: ungoogled-chromium ships several network privacy features
# disabled by default. Enable: kSetIpv6ProbeFalse, kMinimalReferrers,
# kNoCrossOriginReferrers — reduces leakage signals visible to detection sites.
diff --git a/net/base/features.cc b/net/base/features.cc
index adc4b5b6b4..59a3f6f71c 100644
--- a/net/base/features.cc
+++ b/net/base/features.cc
@@ -24,7 +24,7 @@
 
 namespace net::features {
 
-BASE_FEATURE(kSetIpv6ProbeFalse, "SetIpv6ProbeFalse", base::FEATURE_DISABLED_BY_DEFAULT);
+BASE_FEATURE(kSetIpv6ProbeFalse, "SetIpv6ProbeFalse", base::FEATURE_ENABLED_BY_DEFAULT);  // clark-stealth: no IPv6 probe leak
 
 BASE_FEATURE(kAlpsForHttp2, base::FEATURE_ENABLED_BY_DEFAULT);
 
