# clark-stealth-chromium patch #09 — navigator.maxTouchPoints from
# --fingerprint-max-touch-points (integer in [0,16]).
#
# Source: chromium 148.0.7778.96
#   third_party/blink/renderer/core/events/navigator_events.cc
diff --git a/third_party/blink/renderer/core/events/navigator_events.cc b/third_party/blink/renderer/core/events/navigator_events.cc
index a57561775c..8d146b65ef 100644
--- a/third_party/blink/renderer/core/events/navigator_events.cc
+++ b/third_party/blink/renderer/core/events/navigator_events.cc
@@ -30,6 +30,9 @@
 
 #include "third_party/blink/renderer/core/events/navigator_events.h"
 
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "third_party/blink/common/clark_fingerprint_switches.h"
 #include "third_party/blink/renderer/core/frame/local_dom_window.h"
 #include "third_party/blink/renderer/core/frame/local_frame.h"
 #include "third_party/blink/renderer/core/frame/navigator.h"
@@ -38,6 +41,18 @@
 namespace blink {
 
 int32_t NavigatorEvents::maxTouchPoints(Navigator& navigator) {
+  // clark-stealth: --fingerprint-max-touch-points override.
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  if (cl->HasSwitch(clark::switches::kFingerprintMaxTouchPoints)) {
+    int v = 0;
+    if (base::StringToInt(
+            cl->GetSwitchValueASCII(
+                clark::switches::kFingerprintMaxTouchPoints),
+            &v) &&
+        v >= 0 && v <= 16) {
+      return v;
+    }
+  }
   LocalDOMWindow* window = navigator.DomWindow();
   return window ? window->GetFrame()->GetSettings()->GetMaxTouchPoints() : 0;
 }

