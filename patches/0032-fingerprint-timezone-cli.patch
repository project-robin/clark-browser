 #include "third_party/blink/renderer/platform/bindings/v8_per_isolate_data.h"
 #include "third_party/blink/renderer/platform/disk_data_allocator.h"
@@ -367,4 +369,21 @@ void OnProcessBackgrounded() {
   Partitions::AdjustPartitionsForBackground();
 }
 
+// clark-stealth #32: public bridge into TimeZoneController from content/.
+// The handle is intentionally leaked — TimeZoneOverride's destructor calls
+// ClearTimeZoneOverride, which would restore the host (real) timezone the
+// moment our local std::unique_ptr goes out of scope. We want the override
+// to survive for the lifetime of the renderer process.
+void ClarkSetTimeZoneOverride(const std::string& iana_id) {
+  if (iana_id.empty()) return;
+  auto result = TimeZoneController::SetTimeZoneOverride(
+      String::FromUtf8(std::string_view(iana_id)));
+  static base::NoDestructor<
+      std::unique_ptr<TimeZoneController::TimeZoneOverride>>
+      kLeakedHandle(nullptr);
+  if (result.handle) {
+    *kLeakedHandle = std::move(result.handle);
+  }
+}
+
 }  // namespace blink

