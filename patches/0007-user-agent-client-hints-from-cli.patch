+std::string ClarkPlatformVersionForUAMetadata(
+    const std::string& platform) {
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  const std::string explicit_version = cl->GetSwitchValueASCII(
+      clark::switches::kFingerprintPlatformVersion);
+  if (!explicit_version.empty())
+    return explicit_version;
+
+  // Match the frozen desktop UA profiles used by clark-browser defaults.
+  if (platform == "Windows")
+    return "19.0.0";
+  if (platform == "macOS")
+    return "10.15.7";
+  if (platform == "Linux")
+    return std::string();
+  return std::string();
+}
+
+std::string ClarkBrandForUAMetadata() {
+  std::string brand = base::CommandLine::ForCurrentProcess()->
+      GetSwitchValueASCII(clark::switches::kFingerprintBrand);
+  if (brand.empty())
+    brand = "Chrome";
+
+  const std::string lower = base::ToLowerASCII(brand);
+  if (lower == "chrome" || lower == "google chrome")
+    return "Google Chrome";
+  if (lower == "edge" || lower == "microsoft edge")
+    return "Microsoft Edge";
+  if (lower == "opera")
+    return "Opera";
+  if (lower == "vivaldi")
+    return "Vivaldi";
+  if (lower == "chromium")
+    return "Chromium";
+  return brand;
+}
+
+std::string ClarkFullVersionForUAMetadata() {
+  std::string version = base::CommandLine::ForCurrentProcess()->
+      GetSwitchValueASCII(clark::switches::kFingerprintBrandVersion);
+  if (version.empty())
+    version = std::string(version_info::GetVersionNumber());
+  if (version.find('.') == std::string::npos)
+    return base::StrCat({version, ".0.0.0"});
+  return version;
+}
+
+std::string ClarkMajorVersionForUAMetadata() {
+  const std::string full_version = ClarkFullVersionForUAMetadata();
+  const size_t dot = full_version.find('.');
+  return dot == std::string::npos ? full_version : full_version.substr(0, dot);
+}
+
+int ClarkMajorVersionSeed() {
+  int major_version = 0;
+  if (!base::StringToInt(ClarkMajorVersionForUAMetadata(), &major_version) ||
