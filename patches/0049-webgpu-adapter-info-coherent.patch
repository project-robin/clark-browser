+bool ClarkHasGpuFingerprint() {
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  return cl->HasSwitch(clark::switches::kFingerprint) ||
+         cl->HasSwitch(clark::switches::kFingerprintPlatform) ||
+         cl->HasSwitch(clark::switches::kFingerprintGpuVendor) ||
+         cl->HasSwitch(clark::switches::kFingerprintGpuRenderer);
+}
+
+std::string ClarkFingerprintPlatform() {
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  std::string platform =
+      cl->GetSwitchValueASCII(clark::switches::kFingerprintPlatform);
+  if (platform == "macos" || platform == "linux")
+    return platform;
+  return "windows";
+}
+
+const ClarkWebGpuPoolEntry& ClarkPickWebGpu() {
+  const std::string platform = ClarkFingerprintPlatform();
+  size_t candidate_count = 0;
+  for (const auto& entry : kClarkWebGpuPool) {
+    if (platform == entry.platform)
+      ++candidate_count;
+  }
+  if (candidate_count == 0)
+    return kClarkWebGpuPool[0];
+
+  size_t pick =
+      static_cast<size_t>(clark::seed::Hash("webgl-pool") % candidate_count);
+  for (const auto& entry : kClarkWebGpuPool) {
+    if (platform != entry.platform)
+      continue;
+    if (pick == 0)
+      return entry;
+    --pick;
+  }
+  return kClarkWebGpuPool[0];
+}
+
+bool ClarkContains(std::string_view text, std::string_view needle) {
+  return text.find(needle) != std::string_view::npos;
+}
+
+std::string ClarkNormalizeDeviceId(std::string id) {
+  id = base::ToLowerASCII(id);
+  if (!base::StartsWith(id, "0x"))
+    return id;
+  size_t first = id.find_first_not_of('0', 2);
+  if (first == std::string::npos)
+    return "0x0";
+  return "0x" + id.substr(first);
+}
+
+std::string ClarkDeviceIdFromRenderer(const std::string& renderer) {
+  const size_t begin = renderer.find("(0x");
+  if (begin == std::string::npos)
+    return std::string();
+  const size_t end = renderer.find(')', begin);
+  if (end == std::string::npos)
+    return std::string();
+  return ClarkNormalizeDeviceId(renderer.substr(begin + 1, end - begin - 1));
+}
+
+std::string ClarkDescriptionFromRenderer(const std::string& renderer) {
+  size_t start = renderer.find(", ");
+  std::string value =
+      start == std::string::npos ? renderer : renderer.substr(start + 2);
+  static constexpr std::string_view kMetal = "ANGLE Metal Renderer: ";
+  if (base::StartsWith(value, kMetal))
+    value = value.substr(kMetal.size());
+
+  static constexpr std::string_view kMarkers[] = {
+      " (0x", " Direct3D", ", D3D", ", OpenGL", " OpenGL", ", Unspecified"};
+  for (std::string_view marker : kMarkers) {
+    const size_t marker_pos = value.find(marker);
+    if (marker_pos != std::string::npos)
+      value = value.substr(0, marker_pos);
+  }
+  return std::string(base::TrimWhitespaceASCII(value, base::TRIM_ALL));
+}
+
+ClarkWebGpuInfo ClarkInfoFromWebGlStrings(std::string webgl_vendor,
+                                          std::string webgl_renderer) {
+  const std::string joined =
+      base::ToLowerASCII(webgl_vendor + " " + webgl_renderer);
+  ClarkWebGpuInfo info;
+  if (ClarkContains(joined, "nvidia")) {
+    info.vendor = "nvidia";
+    info.architecture = ClarkContains(joined, "rtx 40") ? "ada" : "ampere";
+  } else if (ClarkContains(joined, "amd") || ClarkContains(joined, "radeon")) {
+    info.vendor = "amd";
+    info.architecture = ClarkContains(joined, "rx 7") ? "rdna3" : "rdna";
+  } else if (ClarkContains(joined, "apple")) {
+    info.vendor = "apple";
+    info.architecture = ClarkContains(joined, "m3") ? "apple-m3" :
+        (ClarkContains(joined, "m1") ? "apple-m1" : "apple-m2");
+  } else if (ClarkContains(joined, "intel")) {
+    info.vendor = "intel";
+    info.architecture = ClarkContains(joined, "iris") ? "xe" : "intel";
+  } else {
+    info.vendor = "";
+    info.architecture = "";
+  }
+  info.device = ClarkDeviceIdFromRenderer(webgl_renderer);
+  info.description = ClarkDescriptionFromRenderer(webgl_renderer);
+  return info;
+}
+
+ClarkWebGpuInfo ClarkSelectedWebGpuInfo() {
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  std::string explicit_vendor =
+      cl->GetSwitchValueASCII(clark::switches::kFingerprintGpuVendor);
+  std::string explicit_renderer =
+      cl->GetSwitchValueASCII(clark::switches::kFingerprintGpuRenderer);
+  if (!explicit_vendor.empty() || !explicit_renderer.empty()) {
+    const auto& fallback = ClarkPickWebGpu();
+    if (explicit_vendor.empty())
+      explicit_vendor = fallback.webgl_vendor;
+    if (explicit_renderer.empty())
+      explicit_renderer = fallback.webgl_renderer;
+    return ClarkInfoFromWebGlStrings(explicit_vendor, explicit_renderer);
+  }
+
+  const auto& picked = ClarkPickWebGpu();
+  return {picked.vendor, picked.architecture, picked.device, picked.description};
+}
