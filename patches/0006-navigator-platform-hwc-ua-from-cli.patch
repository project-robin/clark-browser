 String NavigatorBase::userAgent() const {
+  // clark-stealth #05: spoof navigator.userAgent according to
+  // --fingerprint-platform. Strips "HeadlessChrome" tokens regardless.
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  if (cl->HasSwitch(clark::switches::kFingerprintPlatform)) {
+    const std::string p = cl->GetSwitchValueASCII(
+        clark::switches::kFingerprintPlatform);
+    const char* prefix = nullptr;
+    if (p == "windows") {
+      prefix = "Mozilla/5.0 (Windows NT 10.0; Win64; x64)";
+    } else if (p == "macos") {
+      prefix = "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)";
+    } else if (p == "linux") {
+      prefix = "Mozilla/5.0 (X11; Linux x86_64)";
+    }
+    if (prefix) {
+      StringBuilder ua;
+      ua.Append(prefix);
+      ua.Append(
+          " AppleWebKit/537.36 (KHTML, like Gecko) "
+          "Chrome/148.0.0.0 Safari/537.36");
+      return ua.ToString();
+    }
+  }
   ExecutionContext* execution_context = GetExecutionContext();
-  return execution_context ? execution_context->UserAgent() : String();
+  String ua = execution_context ? execution_context->UserAgent() : String();
+  // Strip the "Headless" marker from HeadlessChrome regardless of switches —
+  // a real Chrome never advertises this token.
+  if (!ua.empty()) {
+    ua = ua.Replace("HeadlessChrome", "Chrome");
+  }
+  return ua;
 }
 
 String NavigatorBase::platform() const {
+  // clark-stealth #06: --fingerprint-platform override (takes precedence over
+  // host platform and reduced UA defaults).
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  if (cl->HasSwitch(clark::switches::kFingerprintPlatform)) {
+    const std::string p = cl->GetSwitchValueASCII(
+        clark::switches::kFingerprintPlatform);
+    if (p == "windows") return "Win32";
+    if (p == "macos") return "MacIntel";
+    if (p == "linux") return "Linux x86_64";
+  }
 #if BUILDFLAG(IS_ANDROID)
   // We need to check the ReduceUserAgentMinorVersion feature flag for
   // Android WebView, which does not currently ship a reduced User-Agent.
@@ -70,6 +113,24 @@ void NavigatorBase::Trace(Visitor* visitor) const {
 }
 
 unsigned int NavigatorBase::hardwareConcurrency() const {
+  // clark-stealth #13: --fingerprint-hardware-concurrency takes precedence,
+  // followed by seed-derived value, then reduced/probed values.
+  auto* cl = base::CommandLine::ForCurrentProcess();
+  if (cl->HasSwitch(clark::switches::kFingerprintHardwareConcurrency)) {
+    unsigned int v = 0;
+    if (base::StringToUint(
+            cl->GetSwitchValueASCII(
+                clark::switches::kFingerprintHardwareConcurrency),
+            &v) &&
+        v > 0 && v <= 256) {
+      return v;
+    }
+  }
+  if (cl->HasSwitch(clark::switches::kFingerprint)) {
+    return clark::seed::HardwareConcurrency();
+  }
+  if (base::FeatureList::IsEnabled(blink::features::kReducedSystemInfo))
+    return 2;
   unsigned int hardware_concurrency =
       NavigatorConcurrentHardware::hardwareConcurrency();
 

