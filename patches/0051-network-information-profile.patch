# clark-stealth-chromium patch #51 — navigator.connection profile values.
#
# Source: chromium 148.0.7778.96
#   third_party/blink/renderer/modules/netinfo/network_information.cc
#
# Network Information is explicitly fingerprintable: rtt, downlink, and
# effectiveType expose host/network quality. Headless shells can surface
# impossible values such as rtt=0, which Incolumitas flags as connectionRTT.
# Clark maps these values to a seed-stable network profile, with CLI overrides
# for matching residential, datacenter, mobile, or slow proxies.
diff --git a/third_party/blink/renderer/modules/netinfo/network_information.cc b/third_party/blink/renderer/modules/netinfo/network_information.cc
index 976a3c8c36..39bacd5e8a 100644
