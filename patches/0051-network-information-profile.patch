 #include "third_party/blink/renderer/modules/netinfo/network_information.h"

 #include <algorithm>
+#include <string_view>

 #include "base/time/time.h"
+#include "chrome/common/clark_seed.h"
 #include "third_party/blink/public/mojom/devtools/console_message.mojom-blink.h"
 #include "third_party/blink/public/platform/task_type.h"
 #include "third_party/blink/renderer/bindings/modules/v8/v8_connection_type.h"
@@ -73,6 +75,27 @@ String GetConsoleLogStringForWebHoldback() {
          "and so may be inaccurate";
 }

+WebConnectionType ClarkConnectionTypeToWeb(std::string_view type) {
+  if (type == "cellular") return kWebConnectionTypeCellular4G;
+  if (type == "bluetooth") return kWebConnectionTypeBluetooth;
+  if (type == "ethernet") return kWebConnectionTypeEthernet;
+  if (type == "wifi") return kWebConnectionTypeWifi;
+  if (type == "wimax") return kWebConnectionTypeWimax;
+  if (type == "other") return kWebConnectionTypeOther;
+  if (type == "none") return kWebConnectionTypeNone;
+  return kWebConnectionTypeUnknown;
+}
+
+WebEffectiveConnectionType ClarkEffectiveTypeToWeb(std::string_view type) {
+  if (type == "slow-2g")
+    return WebEffectiveConnectionType::kTypeSlow2G;
+  if (type == "2g")
+    return WebEffectiveConnectionType::kType2G;
+  if (type == "3g")
+    return WebEffectiveConnectionType::kType3G;
+  return WebEffectiveConnectionType::kType4G;
+}
+
 }  // namespace

